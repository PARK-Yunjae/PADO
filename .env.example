# ===========================
# PADO .env — 비밀키 + 튜닝 상수
# 이 파일을 .env로 복사 후 값 채우기
# ===========================

# --- API 키 (비밀) ---
KIWOOM_APPKEY=
KIWOOM_SECRETKEY=
KIWOOM_BASE_URL=https://api.kiwoom.com

DART_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# --- 디스코드 웹훅 (1채널) ---
# 테스트용
DISCORD_WEBHOOK=
# 실전용
# DISCORD_WEBHOOK=

# --- 경로 (기본값 있음, 필요시만 변경) ---
# DATA_DIR=C:/Coding/data
# OHLCV_DIR=C:/Coding/data/ohlcv
# APP_DB_PATH=./data/pado.db

# --- API 호출 제한 ---
API_SLEEP_KIWOOM=0.3
API_SLEEP_DART=0.5
API_SLEEP_NAVER=0.2
API_SLEEP_GEMINI=1.0
API_TIMEOUT=10
API_MAX_RETRY=2
MAX_MATERIAL_EVAL=25

# --- 스캔 필터 ---
SCAN_MIN_SIGNALS=1
SCAN_MIN_SCORE=25
SCAN_MAX_CANDIDATES=60

# --- ClosingBell 스코어링 ---
CB_SCORE_RSI=20
CB_SCORE_MA_ALIGN=20
CB_SCORE_CHANGE=15
CB_SCORE_VOL_BURST=15
CB_SCORE_BROKER=10
CB_SCORE_SHORT=10
CB_SCORE_GC_BONUS=10
CB_SCORE_GGE_BONUS=5
CB_SCORE_OBV_BONUS=3
CB_OVERHEAT_RSI=75

# --- 재차거시 점수 threshold ---
JCGS_PASS_CHART=40
JCGS_PASS_VOLUME=25
JCGS_PASS_MATERIAL=50
JCGS_PASS_MARKET=40
JCGS_FAIL_CHART=10
JCGS_FAIL_VOLUME=5
JCGS_FAIL_MATERIAL=20
JCGS_FAIL_MARKET=15

# --- 재차거시 가중치 ---
JCGS_WEIGHT_CHART=0.30
JCGS_WEIGHT_VOLUME=0.30
JCGS_WEIGHT_MATERIAL=0.20
JCGS_WEIGHT_MARKET=0.20

# --- 시황 배점 ---
MARKET_SCORE_THEME=35
MARKET_SCORE_CALENDAR=25
MARKET_SCORE_NASDAQ=20
MARKET_SCORE_KOSPI_GAP=20

# --- 감시 설정 ---
WATCHLIST_MAX_HOLD_DAYS=20
WATCHLIST_MAX_ITEMS=10

# --- 뉴스 ---
NEWS_SEARCH_COUNT=5
NEWS_SEARCH_FEATURE=true
NEWS_MAX_AGE_DAYS=7

# --- v2: 거래대금 변화율 ---
TRADING_VALUE_MIN=3000000000
TRADING_VALUE_CHANGE_MIN=100
TRADING_VALUE_MA_DAYS=20

# --- v2: 뉴스 매일 수집 ---
NEWS_COLLECT_QUERIES=코스피,코스닥,주식시장,반도체,2차전지,바이오,정부정책경제,수출실적
NEWS_COLLECT_PER_QUERY=30

# --- 로깅 ---
LOG_LEVEL=DEBUG
